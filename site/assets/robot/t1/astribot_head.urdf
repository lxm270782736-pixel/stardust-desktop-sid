<?xml version="1.0" encoding="utf-8"?>
<robot
  name="astribot_head">
  <mujoco>
    <compiler meshdir="./meshes/" balanceinertia="true" discardvisual="false" />
  </mujoco>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1" />
  </material>
  <link
    name="astribot_head_base_link">
    <inertial>
      <origin
        xyz="-0.00115 0.00054 0.035304"
        rpy="0 0 0" />
      <mass
        value="0.3" />
      <inertia
        ixx="0.000553"
        ixy="4e-06"
        ixz="-1.7e-05"
        iyy="0.000505"
        iyz="8e-06"
        izz="0.000239" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="meshes/t1_head/astribot_head_base_link.STL" />
      </geometry>
      <material name="grey" />
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="meshes/t1_head/astribot_head_base_link.STL" />
      </geometry>
    </collision>
  </link>
  <link
    name="astribot_head_link_1">
    <inertial>
      <origin
        xyz="1.9e-05 0.006577 0.081061"
        rpy="0 0 0" />
      <mass
        value="0.256916" />
      <inertia
        ixx="0.001804"
        ixy="0.0"
        ixz="0.0"
        iyy="0.001812"
        iyz="0.000144"
        izz="8.5e-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="meshes/t1_head/astribot_head_link_1.STL" />
      </geometry>
      <material name="grey" />
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="meshes/t1_head/astribot_head_link_1.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="astribot_head_joint_1"
    type="revolute">
    <origin
      xyz="0 0 0"
      rpy="0 0 0" />
    <parent
      link="astribot_head_base_link" />
    <child
      link="astribot_head_link_1" />
    <axis
      xyz="0 0 1" />
    <limit
      lower="-1.6"
      upper="1.6"
      effort="15"
      velocity="2" />
  </joint>
  <link
    name="astribot_head_link_2">
    <inertial>
      <origin
        xyz="0.017185 -0.104538 -0.000323"
        rpy="0 0 0" />
      <mass
        value="0.79" />
      <inertia
        ixx="0.01174"
        ixy="-0.001355"
        ixz="1e-06"
        iyy="0.002937"
        iyz="-2.7e-05"
        izz="0.01243" />
    </inertial>
    <visual>
      <origin
